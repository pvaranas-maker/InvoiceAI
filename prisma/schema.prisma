generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Customer {
  id        Int       @id @default(autoincrement())
  name      String
  company   String?
  email     String?
  phone     String?
  address   String?
  notes     String?
  invoices  Invoice[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  estimates Estimate[]
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber Int
  customerName  String
  subtotal      Float
  tax           Float
  total         Float
  status        String        @default("Draft")
  dueDate DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  customerId    Int?
  customer      Customer?     @relation(fields: [customerId], references: [id])
  items         InvoiceItem[]

  lastReminderSent DateTime?
reminderCount    Int @default(0)

}



model InvoiceItem {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int
  price       Float
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model CompanySettings {
  id          Int      @id @default(autoincrement())
  companyName String
  address     String?
  phone       String?
  email       String?
  website     String?
  taxRate     Float    @default(8.6)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

 model Estimate {
  id             Int            @id @default(autoincrement())
  estimateNumber String
  customerName   String
  subtotal       Float
  tax            Float
  total          Float
  status         String         @default("Draft")
  validUntil     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  customerId     Int?
  customer       Customer?      @relation(fields: [customerId], references: [id])
  items          EstimateItem[]
}

model EstimateItem {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int
  price       Float
  estimateId  Int
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}